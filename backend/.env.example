# Email Verifier — backend env template.
#
#   cp backend/.env.example backend/.env
#
# Then edit ``backend/.env`` with your real values. The systemd unit
# (`deploy/azure/email-verifier.service`), the Fly.io / Render Dockerfiles,
# and the Vercel serverless project all read the same names.
#
# Anything marked REQUIRED below must be set or the backend will refuse to
# start (or every protected route will 503). Optional values default to
# what's shown after the `=`.

# -----------------------------------------------------------------------------
# Auth (Firebase Admin)
# -----------------------------------------------------------------------------

# REQUIRED in production. Service-account JSON, single-line.
# Get it from the Firebase Console:
#   Project settings → Service accounts → Generate new private key
# Paste the entire JSON blob (no newlines) on the right-hand side.
FIREBASE_ADMIN_CREDENTIALS=

# Skip the Firebase verification step in tests / local dev. NEVER set this
# in production.
# EMAIL_VERIFIER_AUTH_TEST_MODE=0

# Firebase Storage bucket name for persisting completed-job result blobs
# (so multi-machine deploys can serve /results.csv from any machine).
# Leave UNSET to auto-derive from the credentials ``project_id`` as
# ``<project_id>.firebasestorage.app`` (the default for new Firebase
# projects, post-Oct-2024). Set explicitly if you use a different bucket
# (e.g. legacy ``<project_id>.appspot.com``, or a separate bucket for
# pre-prod). The bucket must already exist — create one at:
#   https://console.firebase.google.com/project/<your-project>/storage
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated allowlist of origins that may call /api/*.
# Setting this to "*" downgrades to wildcard mode and disables credentialed
# requests (per the CORS spec). When unset, only the standard Vite/uvicorn
# dev origins are allowed (http://localhost:5173, http://localhost:5174,
# http://127.0.0.1:5173, http://127.0.0.1:5174, http://localhost:8000).
EMAIL_VERIFIER_ALLOWED_ORIGINS=https://your-frontend.example.com

# -----------------------------------------------------------------------------
# Deploy tier (multi-tier failover system — see deploy/README.md)
# -----------------------------------------------------------------------------

# 1 = primary (Azure VPS) — full features.
# 2 = full-feature backup (Fly.io always-on free).
# 3 = cold-start backup (Render free / Koyeb free).
# 4 = single-verify-only fallback (Vercel serverless, 10s timeout).
EMAIL_VERIFIER_DEPLOY_TIER=1

# Optional human label shown in the frontend banner. Defaults are computed
# from the tier number (e.g. tier 2 → "Full-feature backup").
# EMAIL_VERIFIER_DEPLOY_LABEL=Primary

# Legacy two-state flag. Setting it to "fallback" is equivalent to
# EMAIL_VERIFIER_DEPLOY_TIER=4. Kept for back-compat with older deploys.
# EMAIL_VERIFIER_DEPLOY_MODE=primary

# -----------------------------------------------------------------------------
# Verifier behaviour
# -----------------------------------------------------------------------------

# Allow live SMTP probing. Most clouds (Azure, GCP, AWS, Fly free) block
# port 25 outbound by default, so this stays off unless you've explicitly
# unblocked it.
EMAIL_VERIFIER_ENABLE_SMTP=false

# Cap on a single bulk upload, in bytes. 0 = unbounded. Default 0.
EMAIL_VERIFIER_MAX_UPLOAD_BYTES=0

# TTL (seconds) for verifier-side DNS / SMTP probe caches. Tune if you
# verify the same domains repeatedly.
EMAIL_VERIFIER_MX_CACHE_TTL=600
EMAIL_VERIFIER_DOMAIN_CACHE_TTL=600
EMAIL_VERIFIER_SMTP_CACHE_TTL=300

# Hard upper bound on entries per cache (LRU-evicted past this).
EMAIL_VERIFIER_CACHE_MAXSIZE=10000

# -----------------------------------------------------------------------------
# Lead Finder providers (optional — leave blank to use only free providers)
# -----------------------------------------------------------------------------
# The Lead Finder uses a multi-provider pipeline. Two providers always work
# without keys: pattern (first.last@domain heuristics) and website_crawl
# (parses /contact, /about, /team for mailto: links and footer emails).
#
# Set keys here to enable the API-backed providers — they give better
# coverage on small / obscure domains.

# Hunter.io free tier: 25 searches/mo + 50 verifications/mo.
# Get a key: https://hunter.io/api-keys
# HUNTER_API_KEY=

# Brave Search API free tier: 2000 queries/mo.
# Get a key: https://api.search.brave.com/app/keys
# BRAVE_SEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Process / serving
# -----------------------------------------------------------------------------

# The job registry is in-memory and does NOT survive being sharded across
# multiple workers. Keep this at 1 unless you've migrated _JOBS to a
# shared store. The systemd unit pins --workers 1; the app logs a loud
# warning at startup if WEB_CONCURRENCY > 1.
WEB_CONCURRENCY=1

# Override the static-files directory the FastAPI app serves the SPA from.
# Defaults to <repo>/frontend/dist. Useful when you build the frontend in
# a different place during deploy.
# EMAIL_VERIFIER_STATIC_DIR=/path/to/frontend/dist

# -----------------------------------------------------------------------------
# Build metadata (set automatically by CI / deploy scripts; safe to leave
# blank in local dev — they only feed /api/version.)
# -----------------------------------------------------------------------------

# EMAIL_VERIFIER_GIT_SHA=
# EMAIL_VERIFIER_BUILD_TIME=
